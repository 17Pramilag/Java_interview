Q : Check if two Strings are Anagrams
Ans : 
public boolean areAnagrams(String s1, String s2) {
    if (s1.length() != s2.length()) return false;
    int[] counts = new int[256]; // Frequency array
    for (int i = 0; i < s1.length(); i++) {
        counts[s1.charAt(i)]++;
        counts[s2.charAt(i)]--;
    }
    for (int count : counts) if (count != 0) return false;
    return true;
}

Q : Remove duplicate characters from a String
Ans : 
public String removeDuplicates(String str) {
    StringBuilder sb = new StringBuilder();
    Set<Character> set = new LinkedHashSet<>();
    for (char c : str.toCharArray()) set.add(c);
    for (char c : set) sb.append(c);
    return sb.toString();
}

Q : Find longest substring without repeating characters
Ans : 
public int lengthOfLongestSubstring(String s) {
    int max = 0, i = 0, j = 0;
    Set<Character> set = new HashSet<>();
    while (j < s.length()) {
        if (!set.contains(s.charAt(j))) {
            set.add(s.charAt(j++));
            max = Math.max(max, set.size());
        } else {
            set.remove(s.charAt(i++));
        }
    }
    return max;
}

