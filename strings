Ans : 
public boolean isPalindrome(String str) {
    int i = 0, j = str.length() - 1;
    while (i < j) {
        if (str.charAt(i++) != str.charAt(j--)) return false;
    }
    return true;
}

Q : Find first non-repeated character in a String
Ans : Use a LinkedHashMap to preserve the order of characters.
public char firstNonRepeated(String str) {
    Map<Character, Integer> map = new LinkedHashMap<>();
    for (char c : str.toCharArray()) map.put(c, map.getOrDefault(c, 0) + 1);
    for (Map.Entry<Character, Integer> entry : map.entrySet()) {
        if (entry.getValue() == 1) return entry.getKey();
    }
    return ' ';
}

Q : Find first repeated character in a String
Ans : Use a HashSet for $O(1)$ lookup.

public char firstRepeated(String str) {
    Set<Character> set = new HashSet<>();
    for (char c : str.toCharArray()) {
        if (set.contains(c)) return c;
        set.add(c);
    }
    return ' ';
}

